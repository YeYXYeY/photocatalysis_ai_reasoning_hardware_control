       <property name="styleSheet">
        <string notr="true">/* QPushButton Default state */
QPushButton {
    background-color: #2E2E2E; /* Light blue background */
    color: white; /* White text */
    border: none; /* Remove border */
    border-radius: 5px; /* Set rounded corners */
}

/* QPushButton Focus state */
QPushButton:focus {
    background-color: #474747; /* Medium blue background */
    color: white; /* Focus stateWhite text */
}

/* QPushButton Hover state */
QPushButton:hover {
    background-color: #474747; /* Dark blue background */
    color: white; /* Hover stateWhite text */
}

/* QPushButton Pressed state */
QPushButton:pressed {
    background-color: #1C1C1C; /* Darker blue background when pressed */
    color: white; /* Pressed stateWhite text */
}</string>
