     <property name="styleSheet">
      <string notr="true">/* QPushButton Default state */
QPushButton {
    background-color: #87CEEB; /* Light blue background */
    color: white; /* White text */
    border: none; /* Remove border */
    padding: 10px; /* Set padding */
    border-radius: 5px; /* Set rounded corners */
}

/* QPushButton Focus state */
QPushButton:focus {
    background-color: #4682B4; /* Medium blue background */
    color: white; /* Focus stateWhite text */
}

/* QPushButton Hover state */
QPushButton:hover {
    background-color: #87CEff; /* Dark blue background */
    color: white; /* Hover stateWhite text */
}

/* QPushButton Pressed state */
QPushButton:pressed {
    background-color: #4A90E2; /* Darker blue background when pressed */
    color: white; /* Pressed stateWhite text */
}</string>
     </property>
