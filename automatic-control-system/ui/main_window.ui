     <property name="styleSheet">
      <string notr="true">QFrame#frame_12 {
	background-color: #fbfbfc; /* Set background color */
	border-radius: 5px;
}
QLabel {
    color: #000000; /* Text color */
    font-size: 18px; /* Font size */
	height: 100px;
    border-radius: 5px; /* Rounded corners */
	qproperty-alignment: 'AlignCenter | AlignBottom'; /* Set alignment with qproperty-alignment */
    font-family: 'Microsoft YaHei'; /* Font set to Microsoft YaHei */
    font-weight: bold; /* Set bold font */
}
QRadioButton {
    color: #000000; /* Text color */
    font-size: 18px; /* Font size */
	height: 100px;
    border-radius: 5px; /* Rounded corners */
	qproperty-alignment: 'AlignCenter | AlignBottom'; /* Set alignment with qproperty-alignment */
    font-family: 'Microsoft YaHei'; /* Font set to Microsoft YaHei */
    font-weight: bold; /* Set bold font */
}

QRadioButton::indicator:checked {
    border: 2px solid #4A90E2; /* Border color when selected */
}
QCheckBox {
    color: #000000; /* Text color */
    font-size: 18px; /* Font size */
    border-radius: 5px; /* Rounded corners */
}
QCheckBox::indicator:checked {
    background-color: #4A90E2; /* Selected checkbox background color */
    border: 1px solid #000000; /* Selected checkbox border color */
    border-radius: 4px; /* Rounded corners */
}
</string>
